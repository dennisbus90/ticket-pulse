{
  "manifestVersion": 1,
  "id": "zigge",
  "version": "1.0.10",
  "name": "Zigge",
  "public": true,
  "description": "AI-powered work item quality analysis, estimation suggestions, and timeline visualization",
  "publisher": "Redt",
  "categories": ["Azure Boards"],
  "tags": [
    "AI",
    "OpenAI",
    "Anthropic",
    "Claude",
    "GPT",
    "Work Items",
    "Quality",
    "Estimation",
    "Story Points",
    "Planning",
    "Timeline",
    "Agile",
    "Scrum",
    "SAFe",
    "Productivity",
    "Azure Boards"
  ],
  "targets": [
    {
      "id": "Microsoft.VisualStudio.Services"
    }
  ],
  "icons": {
    "default": "images/icon.png"
  },
  "content": {
    "details": {
      "path": "overview.md"
    }
  },
  "files": [
    {
      "path": "dist",
      "addressable": true
    },
    {
      "path": "images",
      "addressable": true
    }
  ],
  "scopes": ["vso.work", "vso.work_write"],
  "contributions": [
    {
      "id": "zigge-work-item-form",
      "type": "ms.vss-work-web.work-item-form-group",
      "targets": ["ms.vss-work-web.work-item-form"],
      "properties": {
        "name": "Zigge",
        "uri": "dist/index.html",
        "height": 500
      }
    }
  ]
}
